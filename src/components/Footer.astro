---
/**
 * Footer.astro
 * =============
 * Three-column footer: brand, quick navigation (dynamic),
 * and social links. Bottom bar with copyright and credits.
 */
import { personalInfo, navItems, socialLinks } from '../data/portfolio';

const icons: Record<string, string> = {
  'github':   '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  'mail':     '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  'linkedin': '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  'code':     '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
};

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <a href="#hero" class="footer__logo">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:22px;height:22px;color:var(--color-accent)">
            <Fragment set:html={icons['code']} />
          </svg>
          <span>{personalInfo.firstName}<span class="footer__dot">.</span></span>
        </a>
        <p class="footer__desc">{personalInfo.title} passionné par la création de solutions numériques modernes et performantes.</p>
      </div>

      <!-- Quick nav -->
      <div class="footer__nav-col">
        <h4 class="footer__heading">Navigation</h4>
        <nav class="footer__nav" aria-label="Navigation rapide">
          {navItems.map((item) => (
            <a href={item.href} class="footer__link">{item.label}</a>
          ))}
        </nav>
      </div>

      <!-- Social / Connect -->
      <div class="footer__connect-col">
        <h4 class="footer__heading">Connexion</h4>
        <div class="footer__social">
          {socialLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="footer__social-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={icons[link.icon] || ''} />
              </svg>
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer__bar">
      <p>&copy; {currentYear} {personalInfo.firstName} {personalInfo.lastName}. Tous droits réservés.</p>
      <p class="footer__credits">Built with <span class="footer__tech">Astro</span> · Deployed on <span class="footer__tech">Vercel</span></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: rgba(10, 15, 30, .8);
    backdrop-filter: blur(12px);
    border-top: 1px solid var(--color-border);
    padding: 4rem 0 0;
    margin-top: 2rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  /* Brand */
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-weight: 700;
    font-size: 1.15rem;
    color: #fff;
    text-decoration: none;
    margin-bottom: .75rem;
  }
  .footer__logo:hover { text-decoration: none; }
  .footer__dot { color: var(--color-primary); }
  .footer__desc {
    font-size: .88rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 320px;
  }

  /* Nav */
  .footer__heading {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }
  .footer__link {
    font-size: .88rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color .2s, transform .2s;
    display: inline-block;
  }
  .footer__link:hover {
    color: var(--color-accent);
    transform: translateX(4px);
    text-decoration: none;
  }

  /* Social */
  .footer__social {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .footer__social-link {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-size: .88rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color .2s, transform .2s;
  }
  .footer__social-link svg { width: 16px; height: 16px; }
  .footer__social-link:hover {
    color: var(--color-accent);
    transform: translateX(4px);
    text-decoration: none;
  }

  /* Bottom bar */
  .footer__bar {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: .5rem;
    font-size: .8rem;
    color: var(--color-text-muted);
  }
  .footer__credits { opacity: .6; }
  .footer__tech { color: var(--color-accent); }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer__bar {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
