---
/**
 * BackToTop.astro
 * ================
 * Floating button that appears after 500px scroll, glassmorphism style,
 * smooth scroll to top on click. Fade + rise animation.
 */
---

<button class="btt" id="btt" aria-label="Retour en haut">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btt__icon">
    <path d="m18 15-6-6-6 6"/>
  </svg>
</button>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('btt')!;
    window.addEventListener('scroll', () => {
      requestAnimationFrame(() => {
        btn.classList.toggle('btt--visible', window.scrollY > 500);
      });
    }, { passive: true });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>

<style>
  .btt {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 900;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: rgba(17, 24, 39, .6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--color-text);
    cursor: pointer;
    opacity: 0;
    transform: translateY(16px);
    pointer-events: none;
    transition: opacity .3s, transform .3s, box-shadow .25s, border-color .25s;
  }
  .btt--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .btt:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }
  .btt__icon {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 768px) {
    .btt {
      width: 38px;
      height: 38px;
      bottom: 1.25rem;
      right: 1.25rem;
    }
    .btt__icon { width: 17px; height: 17px; }
  }
</style>
