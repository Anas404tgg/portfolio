---
/**
 * AiAssistant.astro
 * =================
 * Floating AI chatbot assistant — 100% client-side.
 * Uses portfolio.ts data as knowledge base with keyword+regex intent scoring.
 * Adapts to dark/light theme and available data sections.
 */
import {
  personalInfo,
  aboutParagraphs,
  technicalSkills,
  softSkills,
  education,
  experiences,
  publications,
  certifications,
  projects,
  socialLinks,
  stats,
  navItems,
} from '../data/portfolio';

/* Serialise data for the client script */
const portfolioData = JSON.stringify({
  personalInfo,
  aboutParagraphs,
  technicalSkills,
  softSkills,
  education,
  experiences,
  publications,
  certifications,
  projects,
  socialLinks,
  stats,
  navItems,
});
---

<!-- ────────────────── Floating button ────────────────── -->
<div class="ai-fab" id="aiFab" aria-label="Open AI Assistant">
  <span class="ai-fab__ring"></span>
  <img class="ai-fab__icon ai-fab__icon--dark" src="/black.png" alt="" width="44" height="44" />
  <img class="ai-fab__icon ai-fab__icon--light" src="/white.png" alt="" width="44" height="44" />
</div>

<!-- ────────────────── Chat panel ─────────────────────── -->
<div class="ai-panel" id="aiPanel" aria-hidden="true" role="dialog" aria-label="AI Assistant chat">

  <!-- Header -->
  <div class="ai-panel__header">
    <div class="ai-panel__avatar-wrap">
      <img class="ai-panel__avatar ai-panel__avatar--dark" src="/black.png" alt="" width="36" height="36" />
      <img class="ai-panel__avatar ai-panel__avatar--light" src="/white.png" alt="" width="36" height="36" />
    </div>
    <div class="ai-panel__info">
      <span class="ai-panel__name" data-i18n="ai.name">Placio AI Assistant</span>
      <span class="ai-panel__status"><span class="ai-panel__dot"></span><span data-i18n="ai.online">Online</span></span>
    </div>
    <button class="ai-panel__close" id="aiClose" aria-label="Close chat">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Messages -->
  <div class="ai-panel__messages" id="aiMessages"></div>

  <!-- Quick actions -->
  <div class="ai-panel__quick" id="aiQuick"></div>

  <!-- Input -->
  <form class="ai-panel__input-bar" id="aiForm" autocomplete="off">
    <input class="ai-panel__input" id="aiInput" type="text" placeholder="Ask me anything…" data-i18n-placeholder="ai.placeholder" maxlength="300" />
    <button class="ai-panel__send" type="submit" aria-label="Send message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </form>
</div>

<!-- ────────────────── Client script ─────────────────── -->
<script define:vars={{ portfolioData }}>
(function () {
  /* ── Data ───────────────────────────────────────────── */
  const D = JSON.parse(portfolioData);
  const NAME = `${D.personalInfo.firstName} ${D.personalInfo.lastName}`;

  /* ── DOM refs ───────────────────────────────────────── */
  const fab     = document.getElementById('aiFab');
  const panel   = document.getElementById('aiPanel');
  const close   = document.getElementById('aiClose');
  const msgArea = document.getElementById('aiMessages');
  const quick   = document.getElementById('aiQuick');
  const form    = document.getElementById('aiForm');
  const input   = document.getElementById('aiInput');

  let isOpen = false;
  let quickShown = true;
  const HISTORY_KEY = 'placio_chat_history';
  const MAX_HISTORY = 50;

  /* ── Theme helper ───────────────────────────────────── */
  function currentTheme() {
    return document.documentElement.getAttribute('data-theme') || 'dark';
  }
  function applyThemeToChat() {
    const t = currentTheme();
    panel.setAttribute('data-chat-theme', t);
    fab.setAttribute('data-chat-theme', t);
  }
  applyThemeToChat();
  new MutationObserver(applyThemeToChat).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  /* ── HTML escape helper (prevents XSS) ─────────────── */
  function escapeHtml(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  /* ── Mini Markdown renderer ──────────────────────────── */
  /* SAFETY: Only applied to bot responses (trusted internal data).
     User messages are rendered with textContent, never innerHTML. */
  function md(text) {
    return text
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/\[([^\]]+)\]\((#[^)]+)\)/g, '<a href="$2" class="ai-link ai-link--section">$1</a>')
      .replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer" class="ai-link">$1</a>')
      .replace(/\n/g, '<br/>');
  }

  /* ── Message rendering ──────────────────────────────── */
  function addMessage(role, text, save) {
    if (save !== false) saveMsg(role, text);
    const wrap = document.createElement('div');
    wrap.className = `ai-msg ai-msg--${role}`;

    if (role === 'bot') {
      const av = document.createElement('div');
      av.className = 'ai-msg__avatar';
      av.innerHTML = `<img class="ai-msg__avatar-img ai-msg__avatar-img--dark" src="/black.png" width="28" height="28" alt="" /><img class="ai-msg__avatar-img ai-msg__avatar-img--light" src="/white.png" width="28" height="28" alt="" />`;
      wrap.appendChild(av);
    }

    const bubble = document.createElement('div');
    bubble.className = 'ai-bubble';
    if (role === 'user') {
      bubble.textContent = text;
    } else {
      /* Bot responses are trusted (generated from internal portfolio data) */
      bubble.innerHTML = md(text);
    }
    wrap.appendChild(bubble);

    msgArea.appendChild(wrap);
    requestAnimationFrame(() => {
      wrap.classList.add('ai-msg--visible');
      scrollBottom();
    });

    /* section links → close + scroll */
    bubble.querySelectorAll('.ai-link--section').forEach(a => {
      a.addEventListener('click', e => {
        e.preventDefault();
        closePanel();
        const href = a.getAttribute('href');
        /* Only allow #id fragment selectors to prevent selector injection */
        if (href && /^#[a-zA-Z][\w-]*$/.test(href)) {
          const target = document.querySelector(href);
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        }
      });
    });
  }

  function showTyping() {
    const wrap = document.createElement('div');
    wrap.className = 'ai-msg ai-msg--bot ai-typing-wrap';
    const av = document.createElement('div');
    av.className = 'ai-msg__avatar';
    /* Safe: static trusted HTML for theme-aware avatar images */
    av.innerHTML = '<img class="ai-msg__avatar-img ai-msg__avatar-img--dark" src="/black.png" width="28" height="28" alt="" /><img class="ai-msg__avatar-img ai-msg__avatar-img--light" src="/white.png" width="28" height="28" alt="" />';
    wrap.appendChild(av);
    const dots = document.createElement('div');
    dots.className = 'ai-typing';
    dots.innerHTML = '<span></span><span></span><span></span>';
    wrap.appendChild(dots);
    msgArea.appendChild(wrap);
    wrap.classList.add('ai-msg--visible');
    scrollBottom();
    return wrap;
  }

  function scrollBottom() {
    msgArea.scrollTop = msgArea.scrollHeight;
  }

  /* ── localStorage ───────────────────────────────────── */
  function loadHistory() {
    try {
      var parsed = JSON.parse(localStorage.getItem(HISTORY_KEY)) || [];
      _historyCache = parsed;
      return parsed;
    } catch { return []; }
  }
  let _historyCache = null;
  function saveMsg(role, text) {
    const h = _historyCache || loadHistory();
    h.push({ role, text });
    if (h.length > MAX_HISTORY) h.splice(0, h.length - MAX_HISTORY);
    _historyCache = h;
    localStorage.setItem(HISTORY_KEY, JSON.stringify(h));
  }
  function restoreHistory() {
    const h = loadHistory();
    if (h.length) {
      quickShown = false;
      quick.innerHTML = '';
      h.forEach(m => addMessage(m.role, m.text, false));
    }
  }

  /* ── Quick actions ──────────────────────────────────── */
  function buildQuickActions() {
    const L = lang();
    const actions = [];
    if (L === 'fr') {
      actions.push({ label: `Qui est ${D.personalInfo.firstName} ?`, q: `Qui est ${D.personalInfo.firstName} ?` });
      actions.push({ label: 'Compétences', q: 'Quelles sont tes compétences ?' });
      if (D.projects.length) actions.push({ label: 'Projets', q: 'Montre-moi tes projets' });
      if (D.education.length) actions.push({ label: 'Formation', q: 'Quelle est ta formation ?' });
      actions.push({ label: 'Contact', q: 'Comment te contacter ?' });
    } else if (L === 'ar') {
      actions.push({ label: `من هو ${D.personalInfo.firstName}؟`, q: `من هو ${D.personalInfo.firstName}؟` });
      actions.push({ label: 'المهارات', q: 'ما هي مهاراتك؟' });
      if (D.projects.length) actions.push({ label: 'المشاريع', q: 'أرني مشاريعك' });
      if (D.education.length) actions.push({ label: 'التعليم', q: 'ما هو تعليمك؟' });
      actions.push({ label: 'التواصل', q: 'كيف أتواصل معك؟' });
    } else {
      actions.push({ label: `Who is ${D.personalInfo.firstName}?`, q: `Who is ${D.personalInfo.firstName}?` });
      actions.push({ label: 'Skills', q: 'What skills do you have?' });
      if (D.projects.length)      actions.push({ label: 'Projects', q: 'Show me your projects' });
      if (D.publications.length)  actions.push({ label: 'Publications', q: 'Tell me about publications' });
      if (D.education.length)     actions.push({ label: 'Education', q: 'What is your education?' });
      if (D.experiences.length)   actions.push({ label: 'Experience', q: 'Tell me about your experience' });
      if (D.certifications.length) actions.push({ label: 'Certifications', q: 'Show certifications' });
      actions.push({ label: 'Contact', q: 'How can I contact you?' });
    }

    actions.forEach(a => {
      const chip = document.createElement('button');
      chip.className = 'ai-chip';
      chip.textContent = a.label;
      chip.addEventListener('click', () => {
        hideQuick();
        handleUserMessage(a.q);
      });
      quick.appendChild(chip);
    });
  }

  function hideQuick() {
    if (!quickShown) return;
    quickShown = false;
    quick.classList.add('ai-panel__quick--hidden');
  }

  /* ── Current language helper ─────────────────────────── */
  function lang() {
    return (window.__i18n && window.__i18n.getLang) ? window.__i18n.getLang() : 'en';
  }
  function t(key) {
    return (window.__i18n && window.__i18n.t) ? window.__i18n.t(key) : key;
  }

  /* ── Intent scoring engine ─────────────────────────── */
  const intents = {
    greeting:    { kw: ['hello','hi','hey','greetings','bonjour','salut','good morning','good evening','howdy','what\'s up','sup','bonsoir','مرحبا','سلام','أهلا'], score: 0 },
    about:       { kw: ['who','about','yourself','introduction','tell me about','background','bio','profile','describe','qui','présente','présentation','à propos','من','عن','نفسك','تعريف'], score: 0 },
    skills:      { kw: ['skills','stack','technologies','tech','competences','programming','languages','tools','frameworks','what can you do','abilities','compétences','outils','langages','مهارات','تقنيات','أدوات'], score: 0 },
    skillDetail: { kw: [], score: 0 },
    projects:    { kw: ['projects','work','portfolio','built','applications','apps','show me','what have you built','demos','projets','travaux','réalisations','مشاريع','أعمال','تطبيقات'], score: 0 },
    education:   { kw: ['education','study','school','degree','university','diploma','academic','learning','college','esisa','bachelor','courses','études','formation','diplôme','université','école','تعليم','دراسة','جامعة','شهادة'], score: 0 },
    experience:  { kw: ['experience','job','worked','intern','internship','professional','career','employment','company','expérience','emploi','stage','carrière','entreprise','تجربة','عمل','وظيفة','تدريب'], score: 0 },
    publications:{ kw: ['publications','papers','research','articles','published','journal','conference','recherche','منشورات','أبحاث','مقالات'], score: 0 },
    certifications:{ kw: ['certifications','certificates','certified','badge','credentials','accreditation','certificats','شهادات'], score: 0 },
    contact:     { kw: ['contact','reach','email','mail','message','get in touch','hire','available','phone','whatsapp','call','contacter','joindre','تواصل','اتصال','بريد'], score: 0 },
    social:      { kw: ['social','linkedin','github','twitter','links','profiles','socials','connect','follow','network','réseaux','sociaux','شبكات','اجتماعية'], score: 0 },
    stats:       { kw: ['stats','statistics','numbers','achievements','metrics','how many','statistiques','chiffres','إحصائيات','أرقام'], score: 0 },
    navigate:    { kw: ['go to','navigate','show section','scroll to','take me','jump to','open section','aller à','naviguer','montrer','اذهب','انتقل','أرني'], score: 0 },
    help:        { kw: ['help','what can you','options','menu','commands','features','capabilities','assist','aide','aider','مساعدة','ماذا يمكنك'], score: 0 },
    thanks:      { kw: ['thanks','thank you','thx','ty','appreciate','grateful','cheers','merci','remercie','شكرا','شكراً'], score: 0 },
  };

  /* Build all-skill lookup for specific skill queries */
  const allSkills = [];
  D.technicalSkills.forEach(cat => cat.skills.forEach(s => allSkills.push(s.toLowerCase())));

  function detectIntent(text) {
    const lower = text.toLowerCase().trim();
    const scores = {};

    /* reset */
    for (const k in intents) scores[k] = 0;

    /* keyword match with partial & boundary support */
    for (const [intent, { kw }] of Object.entries(intents)) {
      kw.forEach(w => {
        if (lower.includes(w)) scores[intent] += 2;
      });
    }

    /* boost specific skill if directly mentioned */
    const matchedSkill = allSkills.find(s => lower.includes(s));
    if (matchedSkill) scores.skillDetail = 5;

    /* section navigation boost */
    const sectionMap = { home:'#hero', about:'#about', skills:'#skills', education:'#education',
      experience:'#experience', publications:'#publications', certifications:'#certifications',
      projects:'#projects', contact:'#contact' };
    for (const [key] of Object.entries(sectionMap)) {
      if (lower.includes(key) && (lower.includes('go to') || lower.includes('navigate') || lower.includes('scroll') || lower.includes('show') || lower.includes('take me') || lower.includes('jump'))) {
        scores.navigate += 5;
      }
    }

    /* pick top */
    let best = 'fallback';
    let max = 0;
    for (const [k, v] of Object.entries(scores)) {
      if (v > max) { max = v; best = k; }
    }
    return { intent: best, matchedSkill, lower };
  }

  /* ── Response generators ────────────────────────────── */

  const _easterEgg = new Set(['sir t9wd','sir t9awed','sir t9wed']);

  function respond(text) {
    if (_easterEgg.has(text.trim().toLowerCase())) return 'mreg azbi chwiya';
    const { intent, matchedSkill, lower } = detectIntent(text);

    switch (intent) {
      case 'greeting': return greetingReply();
      case 'about':    return aboutReply();
      case 'skills':   return skillsReply();
      case 'skillDetail': return skillDetailReply(matchedSkill);
      case 'projects': return projectsReply();
      case 'education':return educationReply();
      case 'experience':return experienceReply();
      case 'publications':return publicationsReply();
      case 'certifications':return certificationsReply();
      case 'contact':  return contactReply();
      case 'social':   return socialReply();
      case 'stats':    return statsReply();
      case 'navigate': return navigateReply(lower);
      case 'help':     return helpReply();
      case 'thanks':   return thanksReply();
      default:         return fallbackReply();
    }
  }

  function greetingReply() {
    const L = lang();
    if (L === 'fr') {
      const g = [
        `Bonjour ! 👋 Je suis **Placio**, l'assistant virtuel de ${NAME}. Comment puis-je vous aider ?\n\nVous pouvez me poser des questions sur les **compétences**, **projets**, **formation** ou **contact** !`,
        `Salut ! 😊 Bienvenue sur le portfolio de ${NAME}. Je suis là pour vous aider. Que souhaitez-vous savoir ?`,
      ];
      return g[Math.floor(Math.random() * g.length)];
    }
    if (L === 'ar') {
      const g = [
        `مرحبًا! 👋 أنا **بلاسيو**، المساعد الافتراضي لـ ${NAME}. كيف يمكنني مساعدتك؟\n\nيمكنك سؤالي عن **المهارات**، **المشاريع**، **التعليم** أو **التواصل**!`,
        `أهلاً! 😊 مرحبًا بك في معرض أعمال ${NAME}. أنا هنا لمساعدتك. ماذا تريد أن تعرف؟`,
      ];
      return g[Math.floor(Math.random() * g.length)];
    }
    const greetings = [
      `Hello! 👋 I'm **Placio**, ${NAME}'s virtual assistant. How can I help you today?\n\nYou can ask me about **skills**, **projects**, **education**, or **contact** info!`,
      `Hey there! 😊 Welcome to ${NAME}'s portfolio. I'm here to help you learn more about ${D.personalInfo.firstName}. What would you like to know?`,
      `Hi! 👋 Great to see you here! I can tell you about ${D.personalInfo.firstName}'s **skills**, **projects**, **education**, and more. Just ask!`,
    ];
    return greetings[Math.floor(Math.random() * greetings.length)];
  }

  function aboutReply() {
    const L = lang();
    let r = `**${NAME}** — *${D.personalInfo.title}*\n\n`;
    if (L === 'fr') {
      r = `**${NAME}** — *${t('hero.title')}*\n\n`;
      for (let i = 0; i < D.aboutParagraphs.length; i++) r += t('about.p.' + i) + '\n\n';
      r += `📍 Basé à **${D.personalInfo.location}**`;
      if (D.personalInfo.availabilityBadge) r += `\n🟢 *${t('hero.badge')}*`;
      r += `\n\n👉 [En savoir plus](#about)`;
    } else if (L === 'ar') {
      r = `**${NAME}** — *${t('hero.title')}*\n\n`;
      for (let i = 0; i < D.aboutParagraphs.length; i++) r += t('about.p.' + i) + '\n\n';
      r += `📍 مقيم في **${D.personalInfo.location}**`;
      if (D.personalInfo.availabilityBadge) r += `\n🟢 *${t('hero.badge')}*`;
      r += `\n\n👉 [اقرأ المزيد](#about)`;
    } else {
      r += D.aboutParagraphs.map(p => p.text).join('\n\n');
      r += `\n\n📍 Based in **${D.personalInfo.location}**`;
      if (D.personalInfo.availabilityBadge) r += `\n🟢 *${D.personalInfo.availabilityBadge}*`;
      r += `\n\n👉 [Read more about ${D.personalInfo.firstName}](#about)`;
    }
    return r;
  }

  function skillsReply() {
    const L = lang();
    let r;
    if (L === 'fr') {
      r = `Voici les compétences techniques de **${NAME}** :\n\n`;
      D.technicalSkills.forEach((cat, i) => { r += `**${t('skills.cat.' + i)}:** ${cat.skills.join(', ')}\n`; });
      if (D.softSkills.length) r += `\n**Compétences relationnelles:** ${D.softSkills.map((s, i) => t('skills.soft.' + i + '.name')).join(', ')}`;
      r += `\n\n👉 [Voir toutes les compétences](#skills)`;
    } else if (L === 'ar') {
      r = `إليك المهارات التقنية لـ **${NAME}**:\n\n`;
      D.technicalSkills.forEach((cat, i) => { r += `**${t('skills.cat.' + i)}:** ${cat.skills.join(', ')}\n`; });
      if (D.softSkills.length) r += `\n**المهارات الشخصية:** ${D.softSkills.map((s, i) => t('skills.soft.' + i + '.name')).join(', ')}`;
      r += `\n\n👉 [عرض جميع المهارات](#skills)`;
    } else {
      r = `Here are **${NAME}**'s technical skills:\n\n`;
      D.technicalSkills.forEach(cat => { r += `**${cat.category}:** ${cat.skills.join(', ')}\n`; });
      if (D.softSkills.length) r += `\n**Soft Skills:** ${D.softSkills.map(s => s.name).join(', ')}`;
      r += `\n\n👉 [View all skills](#skills)`;
    }
    return r;
  }

  function skillDetailReply(skill) {
    const L = lang();
    let cat = null;
    let catIdx = -1;
    D.technicalSkills.forEach((c, ci) => {
      c.skills.forEach(s => {
        if (s.toLowerCase() === skill) { cat = c.category; catIdx = ci; }
      });
    });
    const skillName = skill.charAt(0).toUpperCase() + skill.slice(1);
    if (L === 'fr') {
      const catLabel = catIdx >= 0 ? t('skills.cat.' + catIdx) : 'technique';
      return `Oui ! **${NAME}** maîtrise **${skillName}** — cela fait partie de l'ensemble *${catLabel}*.\n\n👉 [Voir toutes les compétences](#skills)`;
    }
    if (L === 'ar') {
      const catLabel = catIdx >= 0 ? t('skills.cat.' + catIdx) : 'تقنية';
      return `نعم! **${NAME}** يتقن **${skillName}** — وهي جزء من مجموعة *${catLabel}*.\n\n👉 [عرض جميع المهارات](#skills)`;
    }
    return `Yes! **${NAME}** knows **${skillName}** — it's part of the *${cat || 'technical'}* skill set.\n\n👉 [See all skills](#skills)`;
  }

  function projectsReply() {
    if (!D.projects.length) {
      const L = lang();
      if (L === 'fr') return `${NAME} n'a pas encore listé de projets. Revenez bientôt !`;
      if (L === 'ar') return `لم يقم ${NAME} بإدراج مشاريع بعد. عد قريبًا!`;
      return `${NAME} hasn't listed projects yet. Check back soon!`;
    }
    const L = lang();
    let r;
    if (L === 'fr') {
      r = `Voici les projets de **${NAME}** :\n\n`;
      D.projects.forEach((p, i) => { r += `**${i + 1}. ${t('proj.' + i + '.title')}**\n${t('proj.' + i + '.desc')}\n*Tags: ${p.tags.join(', ')}*\n\n`; });
      r += `👉 [Voir les projets](#projects)`;
    } else if (L === 'ar') {
      r = `إليك مشاريع **${NAME}**:\n\n`;
      D.projects.forEach((p, i) => { r += `**${i + 1}. ${t('proj.' + i + '.title')}**\n${t('proj.' + i + '.desc')}\n*الوسوم: ${p.tags.join(', ')}*\n\n`; });
      r += `👉 [عرض المشاريع](#projects)`;
    } else {
      r = `Here are **${NAME}**'s projects:\n\n`;
      D.projects.forEach((p, i) => { r += `**${i + 1}. ${p.title}**\n${p.description}\n*Tags: ${p.tags.join(', ')}*\n\n`; });
      r += `👉 [View projects section](#projects)`;
    }
    return r;
  }

  function educationReply() {
    if (!D.education.length) {
      const L = lang();
      if (L === 'fr') return `Aucune information sur la formation n'est disponible.`;
      if (L === 'ar') return `لا توجد معلومات عن التعليم حاليًا.`;
      return `No education info available yet.`;
    }
    const L = lang();
    let r;
