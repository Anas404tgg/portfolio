      r += `\nPosez simplement votre question ! 😊`;
    } else if (L === 'ar') {
      r = `يمكنني مساعدتك في:\n\n`;
      r += `• **حول** — تعرف على ${D.personalInfo.firstName}\n`;
      r += `• **المهارات** — التقنية والشخصية\n`;
      if (D.projects.length) r += `• **المشاريع** — الأعمال المنجزة\n`;
      if (D.education.length) r += `• **التعليم** — المسار الأكاديمي\n`;
      if (D.experiences.length) r += `• **التجربة** — المسار المهني\n`;
      if (D.publications.length) r += `• **المنشورات** — أوراق بحثية\n`;
      if (D.certifications.length) r += `• **الشهادات** — الاعتمادات\n`;
      r += `• **التواصل** — تواصل معنا\n`;
      r += `• **التنقل** — "اذهب إلى [قسم]"\n`;
      r += `\nفقط اكتب سؤالك! 😊`;
    } else {
      r = `I can help you with:\n\n`;
      r += `• **About** — Learn about ${D.personalInfo.firstName}\n`;
      r += `• **Skills** — Technical & soft skills\n`;
      if (D.projects.length) r += `• **Projects** — Portfolio work\n`;
      if (D.education.length) r += `• **Education** — Academic background\n`;
      if (D.experiences.length) r += `• **Experience** — Work history\n`;
      if (D.publications.length) r += `• **Publications** — Research papers\n`;
      if (D.certifications.length) r += `• **Certifications** — Credentials\n`;
      r += `• **Contact** — Get in touch\n`;
      r += `• **Navigate** — "Go to [section]"\n`;
      r += `\nJust type your question! 😊`;
    }
    return r;
  }

  function thanksReply() {
    const L = lang();
    if (L === 'fr') {
      const r = [`De rien ! 😊 N'hésitez pas si vous avez d'autres questions.`, `Avec plaisir ! Je reste disponible. 👋`];
      return r[Math.floor(Math.random() * r.length)];
    }
    if (L === 'ar') {
      const r = [`على الرحب والسعة! 😊 لا تتردد إذا كان لديك أسئلة أخرى.`, `بكل سرور! أنا هنا إذا احتجت شيئًا آخر. 👋`];
      return r[Math.floor(Math.random() * r.length)];
    }
    const replies = [
      `You're welcome! 😊 Let me know if you need anything else.`,
      `Happy to help! Feel free to ask more about ${D.personalInfo.firstName}'s work.`,
      `No problem! I'm here if you have more questions. 👋`,
    ];
    return replies[Math.floor(Math.random() * replies.length)];
  }

  function fallbackReply() {
    const L = lang();
    if (L === 'fr') {
      let r = `Je n'ai pas bien compris. 🤔 Je peux vous aider avec :\n\n`;
      r += `• **Compétences** et technologies\n• **Projets** et portfolio\n• **Formation** et parcours\n• Informations de **contact**\n\n`;
      r += `Essayez par exemple *"Quelles sont les compétences de ${D.personalInfo.firstName} ?"* ou *"Montre-moi tes projets"*.`;
      return r;
    }
    if (L === 'ar') {
      let r = `لم أفهم ذلك جيدًا. 🤔 يمكنني مساعدتك في:\n\n`;
      r += `• **المهارات** والتقنيات\n• **المشاريع** والأعمال\n• **التعليم** والمسار\n• معلومات **التواصل**\n\n`;
      r += `جرب مثلاً *"ما مهارات ${D.personalInfo.firstName}؟"* أو *"أرني مشاريعك"*.`;
      return r;
    }
    let r = `I'm not sure I understood that. 🤔 I can help you with:\n\n`;
    r += `• **Skills** & technologies\n`;
    r += `• **Projects** & portfolio\n`;
    r += `• **Education** & background\n`;
    r += `• **Contact** information\n\n`;
    r += `Try asking something like *"What skills does ${D.personalInfo.firstName} have?"* or *"Show me your projects"*.`;
    return r;
  }

  /* ── User message handler ───────────────────────────── */
  function handleUserMessage(text) {
    addMessage('user', text);
    const typing = showTyping();
    const delay = 600 + Math.random() * 600;
    setTimeout(() => {
      typing.remove();
      const reply = respond(text);
      addMessage('bot', reply);
    }, delay);
  }

  /* ── Open / close ───────────────────────────────────── */
  function openPanel() {
    isOpen = true;
    panel.classList.add('ai-panel--open');
    panel.setAttribute('aria-hidden', 'false');
    fab.classList.add('ai-fab--hidden');
    input.focus();
    scrollBottom();
  }

  function closePanel() {
    isOpen = false;
    panel.classList.remove('ai-panel--open');
    panel.setAttribute('aria-hidden', 'true');
    fab.classList.remove('ai-fab--hidden');
  }

  /* ── Events ─────────────────────────────────────────── */
  fab.addEventListener('click', openPanel);
  close.addEventListener('click', closePanel);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && isOpen) closePanel();
  });

  form.addEventListener('submit', e => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    hideQuick();
    handleUserMessage(text);
  });

  /* ── Init ───────────────────────────────────────────── */
  const history = loadHistory();
  if (history.length) {
    restoreHistory();
  } else {
    addMessage('bot', greetingReply(), true);
    buildQuickActions();
  }

  /* Rebuild quick actions when language changes */
  window.addEventListener('langchange', function () {
    if (quickShown) {
      quick.innerHTML = '';
      buildQuickActions();
    }
  });
})();
</script>

<!-- ────────────────── Styles ─────────────────────────── -->
<style is:global>
  /* ── Floating action button ──────────────────────────── */
  .ai-fab {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 9998;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--color-bg-glass);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform .25s cubic-bezier(.4,0,.2,1), box-shadow .25s ease, opacity .3s ease;
    animation: aiFabIn .6s cubic-bezier(.34,1.56,.64,1) both;
    animation-delay: 1s;
  }
  @keyframes aiFabIn {
    from { opacity: 0; transform: scale(0) translateY(20px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .ai-fab:hover {
    transform: scale(1.08);
    box-shadow: var(--shadow-lg), 0 0 20px var(--color-glow);
  }
  .ai-fab:active { transform: scale(0.95); }
  .ai-fab--hidden { opacity: 0; pointer-events: none; transform: scale(0); }

  /* theme-based icon visibility */
  .ai-fab__icon { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; position: absolute; transition: opacity .3s ease; }
  .ai-fab__icon--dark  { opacity: 1; }
  .ai-fab__icon--light { opacity: 0; }
  [data-chat-theme="light"] .ai-fab__icon--dark  { opacity: 0; }
  [data-chat-theme="light"] .ai-fab__icon--light { opacity: 1; }

  /* pulse ring */
  .ai-fab__ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
    opacity: 0;
    animation: aiFabRing 2.5s cubic-bezier(.4,0,.6,1) infinite;
  }
  @keyframes aiFabRing {
    0%   { transform: scale(.85); opacity: .7; }
    100% { transform: scale(1.4);  opacity: 0; }
  }

  /* ── Panel ───────────────────────────────────────────── */
  .ai-panel {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 9999;
    width: 380px;
    max-height: min(600px, calc(100dvh - 3rem));
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    overflow: hidden;

    /* closed state */
    opacity: 0;
    transform: scale(.85) translateY(30px);
    pointer-events: none;
    transition: opacity .35s cubic-bezier(.34,1.56,.64,1),
                transform .35s cubic-bezier(.34,1.56,.64,1);
  }
  .ai-panel--open {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  /* ── Panel header ────────────────────────────────────── */
  .ai-panel__header {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .875rem 1rem;
    background: var(--gradient);
    color: #fff;
    flex-shrink: 0;
  }
  .ai-panel__avatar-wrap {
    position: relative;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }
  .ai-panel__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    position: absolute;
    top: 0; left: 0;
    transition: opacity .3s ease;
  }
  .ai-panel__avatar--dark  { opacity: 1; }
  .ai-panel__avatar--light { opacity: 0; }
  [data-chat-theme="light"] .ai-panel__avatar--dark  { opacity: 0; }
  [data-chat-theme="light"] .ai-panel__avatar--light { opacity: 1; }

  .ai-panel__info { flex: 1; min-width: 0; }
  .ai-panel__name {
    display: block;
    font-weight: 700;
    font-size: .9rem;
    line-height: 1.2;
  }
  .ai-panel__status {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: .72rem;
    opacity: .9;
  }
  .ai-panel__dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #34d399;
    display: inline-block;
    box-shadow: 0 0 6px #34d399;
  }
  .ai-panel__close {
    background: rgba(255,255,255,.15);
    border: none;
    border-radius: 50%;
    width: 32px; height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    cursor: pointer;
    transition: background .2s;
    flex-shrink: 0;
  }
  .ai-panel__close:hover { background: rgba(255,255,255,.25); }

  /* ── Messages area ───────────────────────────────────── */
  .ai-panel__messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }
  .ai-panel__messages::-webkit-scrollbar { width: 5px; }
  .ai-panel__messages::-webkit-scrollbar-track { background: transparent; }
  .ai-panel__messages::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 10px; }

  /* ── Message bubbles ─────────────────────────────────── */
  .ai-msg {
    display: flex;
    align-items: flex-end;
    gap: .5rem;
    max-width: 88%;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .3s ease, transform .3s ease;
  }
