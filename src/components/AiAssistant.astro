  function navigateReply(lower) {
    const L = lang();
    const sectionMap = { home:'#hero', about:'#about', skills:'#skills', education:'#education',
      experience:'#experience', publications:'#publications', certifications:'#certifications',
      projects:'#projects', contact:'#contact' };
    const sectionNamesFr = { home:'accueil', about:'à propos', skills:'compétences', education:'formation', experience:'expérience', publications:'publications', certifications:'certifications', projects:'projets', contact:'contact' };
    const sectionNamesAr = { home:'الرئيسية', about:'حول', skills:'المهارات', education:'التعليم', experience:'التجربة', publications:'المنشورات', certifications:'الشهادات', projects:'المشاريع', contact:'التواصل' };
    for (const [key, hash] of Object.entries(sectionMap)) {
      if (lower.includes(key)) {
        if (L === 'fr') return `Bien sûr ! Je vous emmène à la section **${sectionNamesFr[key]}**… 👉 [Aller à ${sectionNamesFr[key]}](${hash})`;
        if (L === 'ar') return `بالتأكيد! سأنقلك إلى قسم **${sectionNamesAr[key]}**… 👉 [اذهب إلى ${sectionNamesAr[key]}](${hash})`;
        return `Sure! Taking you to the **${key}** section now… 👉 [Go to ${key}](${hash})`;
      }
    }
    if (L === 'fr') return `Quelle section souhaitez-vous visiter ? Vous pouvez dire : ${Object.values(sectionNamesFr).join(', ')}.`;
    if (L === 'ar') return `أي قسم تريد زيارته؟ يمكنك قول: ${Object.values(sectionNamesAr).join(', ')}.`;
    return `Which section would you like to visit? You can say: ${Object.keys(sectionMap).join(', ')}.`;
  }

  function helpReply() {
    const L = lang();
    let r;
    if (L === 'fr') {
      r = `Je peux vous aider avec :\n\n`;
      r += `• **À propos** — En savoir plus sur ${D.personalInfo.firstName}\n`;
      r += `• **Compétences** — Techniques et relationnelles\n`;
      if (D.projects.length) r += `• **Projets** — Réalisations\n`;
      if (D.education.length) r += `• **Formation** — Parcours académique\n`;
      if (D.experiences.length) r += `• **Expérience** — Parcours professionnel\n`;
      if (D.publications.length) r += `• **Publications** — Articles de recherche\n`;
      if (D.certifications.length) r += `• **Certifications** — Accréditations\n`;
      r += `• **Contact** — Entrer en contact\n`;
