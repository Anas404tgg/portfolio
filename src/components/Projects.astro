---
/**
 * Projects.astro
 * ===============
 * Grid of project cards with decorative gradient watermark numbers,
 * tech tag chips, external links and hover effects.
 */
import { projects } from '../data/portfolio';

const externalLinkIcon = '<path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>';
const arrowRightIcon   = '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>';
const githubIcon       = '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>';
---

<section id="projects" class="section">
  <div class="container">
    <div class="section__header reveal">
      <p class="section__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px">
          <path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/>
        </svg>
        <span data-i18n="projects.label">Projects</span>
      </p>
      <h2 class="section__title" data-i18n="projects.title">My Work</h2>
      <div class="section__divider"></div>
    </div>

    <div class="projects__grid stagger">
      {projects.map((proj, i) => (
        <div class="projects__card glass-card reveal">
          <!-- Watermark number -->
          <span class="projects__watermark gradient-text">{String(i + 1).padStart(2, '0')}</span>

          <h3 class="projects__title">
            {proj.url ? (
              <a href={proj.url} target="_blank" rel="noopener noreferrer" class="projects__title-link">
                <span data-i18n={`proj.${i}.title`}>{proj.title}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="projects__ext-icon">
                  <Fragment set:html={externalLinkIcon} />
                </svg>
              </a>
            ) : (
              <span data-i18n={`proj.${i}.title`}>{proj.title}</span>
            )}
          </h3>

          <p class="projects__desc" data-i18n={`proj.${i}.desc`}>{proj.description}</p>

          <div class="projects__tags">
            {proj.tags.map((tag) => (
              <span class="projects__tag">{tag}</span>
            ))}
          </div>

          <div class="projects__links">
            {proj.github && (
              <a href={proj.github} target="_blank" rel="noopener noreferrer" class="projects__link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={githubIcon} />
                </svg>
                <span data-i18n="projects.code">Code</span>
              </a>
            )}
            {proj.url && (
              <a href={proj.url} target="_blank" rel="noopener noreferrer" class="projects__link projects__link--primary">
                <span data-i18n="projects.viewProject">View Project</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="projects__arrow">
                  <Fragment set:html={arrowRightIcon} />
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .projects__card {
    padding: 1.75rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .projects__watermark {
    font-size: 3.5rem;
    font-weight: 900;
    opacity: .12;
    position: absolute;
    top: .5rem;
    right: 1rem;
    line-height: 1;
    pointer-events: none;
  }

  .projects__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: .75rem;
    position: relative;
    z-index: 1;
  }
  .projects__title-link {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    color: var(--color-text-heading);
    text-decoration: none;
    transition: color .2s;
  }
  .projects__title-link:hover { color: var(--color-accent); text-decoration: none; }
  .projects__ext-icon { width: 16px; height: 16px; }

  .projects__desc {
    font-size: .88rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
    flex: 1;
  }

  .projects__tags {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
    margin-bottom: 1.25rem;
  }
  .projects__tag {
    padding: .2rem .6rem;
    border-radius: 999px;
    background: var(--color-accent-subtle);
    border: 1px solid var(--color-accent-subtle-border);
    font-size: .75rem;
    color: var(--color-accent);
  }

  .projects__links {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
  }
  .projects__link {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-size: .82rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: .35rem .75rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    transition: color .2s, border-color .2s;
  }
  .projects__link svg { width: 15px; height: 15px; }
  .projects__link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }
  .projects__link--primary {
    background: var(--gradient);
    border: none;
    color: #fff;
  }
  .projects__link--primary:hover {
    box-shadow: var(--shadow-glow);
    color: #fff;
  }
  .projects__arrow {
    width: 14px; height: 14px;
    transition: transform .3s;
  }
  .projects__link--primary:hover .projects__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
