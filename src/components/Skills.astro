---
/**
 * Skills.astro
 * =============
 * Technical skills grid with icon cards and chips, optional soft skills
 * row, divider labels, and hover glow effects.
 */
import { technicalSkills, softSkills } from '../data/portfolio';

const icons: Record<string, string> = {
  'code':           '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  'globe':          '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>',
  'database':       '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>',
  'wrench':         '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  'users':          '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  'lightbulb':      '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>',
  'clock':          '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  'message-circle': '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>',
  'cpu':            '<rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/>',
  'server':         '<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>',
  'terminal':       '<polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/>',
};
---

<section id="skills" class="section">
  <div class="container">
    <div class="section__header reveal">
      <p class="section__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px">
          <Fragment set:html={icons['cpu']} />
        </svg>
        Compétences
      </p>
      <h2 class="section__title">Mon Expertise</h2>
      <div class="section__divider"></div>
    </div>

    <!-- Technical Skills -->
    <div class="divider-label reveal"><span>Technical Skills</span></div>

    <div class="skills__grid stagger">
      {technicalSkills.map((cat) => (
        <div class="skills__card glass-card reveal">
          <div class="skills__icon-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="skills__icon">
              <Fragment set:html={icons[cat.icon] || icons['code']} />
            </svg>
          </div>
          <h3 class="skills__category">{cat.category}</h3>
          <div class="skills__chips">
            {cat.skills.map((s) => (
              <span class="skills__chip">{s}</span>
            ))}
          </div>
          <span class="skills__count">{cat.skills.length} compétences</span>
        </div>
      ))}
    </div>

    <!-- Soft Skills (optional) -->
    {softSkills.length > 0 && (
      <>
        <div class="divider-label reveal"><span>Soft Skills</span></div>
        <div class="soft__grid stagger">
          {softSkills.map((s) => (
            <div class="soft__card glass-card reveal">
              <div class="soft__icon-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="soft__icon">
                  <Fragment set:html={icons[s.icon] || ''} />
                </svg>
              </div>
              <div>
                <h4 class="soft__name">{s.name}</h4>
                <p class="soft__desc">{s.description}</p>
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</section>

<style>
  /* ── Technical skills grid ─────────────────────────── */
  .skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .skills__card {
    padding: 1.5rem;
  }

  .skills__icon-wrap {
    width: 48px; height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: rgba(99, 102, 241, .08);
    border: 1px solid rgba(99, 102, 241, .15);
    margin-bottom: 1rem;
    transition: transform .3s, box-shadow .3s;
  }
  .skills__card:hover .skills__icon-wrap {
    transform: scale(1.1);
    box-shadow: 0 0 20px rgba(99, 102, 241, .3);
  }
  .skills__icon {
    width: 24px; height: 24px;
    color: var(--color-accent);
  }

  .skills__category {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: .75rem;
  }

  .skills__chips {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
    margin-bottom: .75rem;
  }
  .skills__chip {
    display: inline-block;
    padding: .2rem .6rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, .08);
    border: 1px solid rgba(99, 102, 241, .12);
    font-size: .78rem;
    color: var(--color-text-muted);
  }

  .skills__count {
    font-family: var(--font-mono);
    font-size: .72rem;
    color: var(--color-text-muted);
    opacity: .6;
  }

  /* ── Soft skills grid ──────────────────────────────── */
  .soft__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .soft__card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
  }
  .soft__icon-wrap {
    width: 40px; height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: rgba(167, 139, 250, .08);
    border: 1px solid rgba(167, 139, 250, .15);
    flex-shrink: 0;
    transition: transform .3s, box-shadow .3s;
  }
  .soft__card:hover .soft__icon-wrap {
    transform: scale(1.1);
    box-shadow: 0 0 20px rgba(167, 139, 250, .3);
  }
  .soft__icon {
    width: 20px; height: 20px;
    color: var(--color-accent);
  }
  .soft__name {
    font-size: .9rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: .25rem;
  }
  .soft__desc {
    font-size: .82rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
