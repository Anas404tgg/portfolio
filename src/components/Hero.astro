---
/**
 * Hero.astro
 * ==========
 * Full-height hero section with animated gradient name, profile photo
 * in a hue-rotating ring, availability badge with pulsing dot,
 * action buttons, CV export modal, social pills, stats bar, and scroll indicator.
 */
import {
  personalInfo, stats, socialLinks, projects, publications,
  technicalSkills, softSkills, education, experiences, certifications,
} from '../data/portfolio';

const icons: Record<string, string> = {
  'github':   '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  'mail':     '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
  'linkedin': '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
  'arrow-down':'<path d="M12 5v14"/><path d="m19 12-7 7-7-7"/>',
  'folder-open':'<path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/>',
  'send':     '<path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>',
  'message-circle': '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>',
  'download': '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>',
  'file-text':'<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>',
};

/* Build action buttons dynamically */
const actionButtons: { label: string; href: string; icon: string; primary?: boolean; id?: string }[] = [
  { label: 'View My Projects', href: '#projects', icon: 'folder-open', primary: true },
  { label: 'Contact Me', href: '#contact', icon: 'send' },
];

/** Serialise CV data for client-side generation */
const cvData = JSON.stringify({
  personalInfo, technicalSkills, softSkills, education, experiences,
  publications, certifications, projects, socialLinks,
});
---

<section id="hero" class="hero">
  <div class="hero__inner container">
    <!-- Text content -->
    <div class="hero__content">
      <!-- Availability badge -->
      <div class="hero__badge reveal">
        <span class="hero__badge-dot"></span>
        <span data-i18n="hero.badge">{personalInfo.availabilityBadge}</span>
      </div>

      <h1 class="hero__name reveal">
        <span class="gradient-text">{personalInfo.firstName} {personalInfo.lastName}</span>
      </h1>

      <p class="hero__title reveal" data-i18n="hero.title">{personalInfo.title}</p>
      <p class="hero__subtitle reveal" data-i18n="hero.subtitle">{personalInfo.subtitle}</p>

      <!-- Action buttons -->
      <div class="hero__actions reveal">
        {actionButtons.map((btn) => (
          <a href={btn.href} class:list={['hero__btn', { 'hero__btn--primary': btn.primary }]} data-i18n={btn.primary ? 'hero.viewProjects' : 'hero.contactMe'}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icons[btn.icon] || ''} />
            </svg>
            {btn.label}
          </a>
        ))}
        <!-- Export CV button -->
        <button class="hero__btn" id="cvExportBtn" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <Fragment set:html={icons['download']} />
          </svg>
          <span data-i18n="hero.exportCv">Export CV</span>
        </button>
      </div>

      <!-- Social pills -->
      <div class="hero__social reveal">
        {socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="hero__pill">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icons[link.icon] || ''} />
            </svg>
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Profile photo -->
    <div class="hero__photo-wrap reveal">
      <div class="hero__photo-ring">
        <img
          src={personalInfo.avatarUrl}
          alt={`${personalInfo.firstName} ${personalInfo.lastName}`}
          class="hero__photo"
          width="280"
          height="280"
          loading="eager"
        />
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="hero__stats container reveal">
    {stats.map((s, i) => (
      <div class="hero__stat">
        <span class="hero__stat-value gradient-text" data-i18n={`stats.${i}.value`}>{s.value}</span>
        <span class="hero__stat-label" data-i18n={`stats.${i}.label`}>{s.label}</span>
      </div>
    ))}
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll reveal" aria-hidden="true">
    <div class="hero__mouse">
      <div class="hero__mouse-wheel"></div>
    </div>
    <span class="hero__scroll-text" data-i18n="hero.scroll">Scroll</span>
  </div>

  <!-- CV Export Modal -->
  <div class="cv-modal" id="cvModal" aria-hidden="true" role="dialog" aria-label="Export CV">
    <div class="cv-modal__backdrop" id="cvBackdrop"></div>
    <div class="cv-modal__panel glass-card">
      <div class="cv-modal__header">
        <h3 class="cv-modal__title" data-i18n="cv.title">Export CV</h3>
        <button class="cv-modal__close" id="cvClose" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <p class="cv-modal__desc" data-i18n="cv.desc">Choose a format to download the ATS-compatible CV.</p>
      <div class="cv-modal__options">
        <button class="cv-modal__option" id="cvPdf" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;color:var(--color-accent)">
            <Fragment set:html={icons['file-text']} />
          </svg>
          <span class="cv-modal__opt-label" data-i18n="cv.pdf">PDF Format</span>
          <span class="cv-modal__opt-hint" data-i18n="cv.pdfHint">Best for applications</span>
        </button>
        <button class="cv-modal__option" id="cvWord" type="button">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;color:var(--color-accent)">
            <Fragment set:html={icons['file-text']} />
          </svg>
          <span class="cv-modal__opt-label" data-i18n="cv.word">Word Format</span>
          <span class="cv-modal__opt-hint" data-i18n="cv.wordHint">.doc for editing</span>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- CV Export Script -->
<script define:vars={{ cvData }}>
(function () {
  const D = JSON.parse(cvData);
  const NAME = `${D.personalInfo.firstName} ${D.personalInfo.lastName}`;

  const modal = document.getElementById('cvModal');
  const btn = document.getElementById('cvExportBtn');
  const closeBtn = document.getElementById('cvClose');
  const backdrop = document.getElementById('cvBackdrop');
  const pdfBtn = document.getElementById('cvPdf');
  const wordBtn = document.getElementById('cvWord');

  /** Build ATS-friendly plain-text CV content */
  function buildCvText() {
    let cv = '';
    cv += `${NAME}\n`;
    cv += `${D.personalInfo.title}\n`;
    cv += '='.repeat(50) + '\n\n';

    /* Contact */
    cv += 'CONTACT\n' + '-'.repeat(30) + '\n';
    cv += `Email: ${D.personalInfo.emails.join(', ')}\n`;
    if (D.personalInfo.phone) cv += `Phone: ${D.personalInfo.phone}\n`;
    cv += `Location: ${D.personalInfo.location}\n`;
    D.socialLinks.forEach(l => { cv += `${l.label}: ${l.url}\n`; });
    cv += '\n';

    /* Summary */
    cv += 'SUMMARY\n' + '-'.repeat(30) + '\n';
    cv += D.personalInfo.subtitle + '\n\n';

    /* Skills */
    if (D.technicalSkills.length) {
      cv += 'TECHNICAL SKILLS\n' + '-'.repeat(30) + '\n';
      D.technicalSkills.forEach(c => { cv += `${c.category}: ${c.skills.join(', ')}\n`; });
      cv += '\n';
    }
    if (D.softSkills.length) {
      cv += 'SOFT SKILLS\n' + '-'.repeat(30) + '\n';
      cv += D.softSkills.map(s => s.name).join(', ') + '\n\n';
    }

    /* Education */
    if (D.education.length) {
      cv += 'EDUCATION\n' + '-'.repeat(30) + '\n';
      D.education.forEach(e => {
        cv += `${e.degree} — ${e.field}\n`;
        cv += `${e.institution} (${e.period})\n`;
        cv += `${e.description}\n\n`;
      });
    }

    /* Experience */
    if (D.experiences.length) {
      cv += 'EXPERIENCE\n' + '-'.repeat(30) + '\n';
      D.experiences.forEach(e => {
        cv += `${e.role} — ${e.company} (${e.period})\n`;
        cv += `${e.description}\n\n`;
      });
    }

    /* Projects */
    if (D.projects.length) {
      cv += 'PROJECTS\n' + '-'.repeat(30) + '\n';
      D.projects.forEach(p => {
        cv += `${p.title}\n${p.description}\nTechnologies: ${p.tags.join(', ')}\n\n`;
      });
    }

    /* Publications */
    if (D.publications.length) {
      cv += 'PUBLICATIONS\n' + '-'.repeat(30) + '\n';
      D.publications.forEach(p => {
        cv += `${p.title} (${p.year}) — ${p.journal}\n${p.authors}\n\n`;
      });
    }

    /* Certifications */
    if (D.certifications.length) {
      cv += 'CERTIFICATIONS\n' + '-'.repeat(30) + '\n';
      D.certifications.forEach(c => {
        cv += `${c.name} — ${c.issuer} (${c.date})\n`;
      });
      cv += '\n';
    }

    return cv;
  }

  /** Generate ATS-friendly HTML for PDF printing */
  function buildCvHtml() {
    const text = buildCvText();
    return `<!DOCTYPE html><html><head><meta charset="utf-8"><title>CV — ${NAME}</title>
<style>body{font-family:Arial,Helvetica,sans-serif;font-size:11pt;line-height:1.5;color:#222;max-width:700px;margin:2cm auto;padding:0 1cm}
pre{white-space:pre-wrap;word-wrap:break-word;font-family:inherit;font-size:inherit;margin:0}
@media print{body{margin:1cm}}</style></head>
<body><pre>${text.replace(/&/g,'&amp;').replace(/</g,'&lt;')}</pre></body></html>`;
  }

  /** Download as PDF via print dialog */
  function downloadPdf() {
    const w = window.open('', '_blank');
    if (!w) {
      alert('Popup blocked! Please allow popups for this site to export your CV as PDF.');
      return;
    }
    w.document.write(buildCvHtml());
    w.document.close();
    setTimeout(() => { w.print(); }, 400);
    closeModal();
  }

  /** Download as .doc (MS Word compatible HTML) */
  function downloadWord() {
    const text = buildCvText();
    const html = `<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
<head><meta charset="utf-8"><title>CV</title>
<style>body{font-family:Arial,sans-serif;font-size:11pt;line-height:1.5}pre{white-space:pre-wrap;font-family:inherit;font-size:inherit}</style></head>
<body><pre>${text.replace(/&/g,'&amp;').replace(/</g,'&lt;')}</pre></body></html>`;
    const blob = new Blob(['\ufeff', html], { type: 'application/msword' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `CV_${NAME.replace(/\s+/g, '_')}.doc`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    closeModal();
  }

  function openModal() {
    modal.classList.add('cv-modal--open');
    modal.setAttribute('aria-hidden', 'false');
  }
  function closeModal() {
    modal.classList.remove('cv-modal--open');
    modal.setAttribute('aria-hidden', 'true');
  }

  btn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  pdfBtn.addEventListener('click', downloadPdf);
  wordBtn.addEventListener('click', downloadWord);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
})();
</script>

<style>
  /* ── Hero section ───────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 7rem 0 3rem;
    position: relative;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 3rem;
  }

  /* ── Text content ───────────────────────────────────── */
  .hero__content {
    max-width: 640px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .4rem 1rem;
    border-radius: 999px;
    background: var(--color-success-subtle);
    border: 1px solid var(--color-success-subtle-border);
    font-size: .85rem;
    color: var(--color-success);
    margin-bottom: 1.5rem;
  }
  .hero__badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(52,211,153,.5); }
    50%      { box-shadow: 0 0 0 6px rgba(52,211,153,0); }
  }

  .hero__name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: .5rem;
  }

  .hero__tagline {
    font-family: var(--font-mono);
    font-size: clamp(.85rem, 1.5vw, 1rem);
    color: var(--color-text-muted);
    letter-spacing: .05em;
    margin-bottom: .75rem;
    opacity: .8;
  }

  .hero__title {
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: .75rem;
  }

  .hero__subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 540px;
  }

  /* ── Actions ────────────────────────────────────────── */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
    margin-bottom: 1.5rem;
  }
  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .7rem 1.4rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: .9rem;
    text-decoration: none;
    transition: transform .2s, box-shadow .2s;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: var(--color-bg-elevated);
  }
  .hero__btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .hero__btn--primary {
    background: var(--gradient);
    border: none;
    color: #fff;
  }
  .hero__btn--primary:hover {
    box-shadow: var(--shadow-glow);
  }
  .hero__btn svg { width: 18px; height: 18px; }

  /* ── Social pills ───────────────────────────────────── */
  .hero__social {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
  }
  .hero__pill {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .35rem .85rem;
    border-radius: 999px;
    background: var(--color-bg-elevated);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    font-size: .82rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color .2s, border-color .2s, transform .2s;
  }
  .hero__pill:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .hero__pill svg { width: 15px; height: 15px; }

  /* ── Photo ──────────────────────────────────────────── */
  .hero__photo-wrap {
    display: flex;
    justify-content: center;
  }
  .hero__photo-ring {
    position: relative;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    padding: 5px;
    transition: transform .4s cubic-bezier(.34,1.56,.64,1);
  }
  .hero__photo-ring::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--gradient);
    animation: hue-spin 8s linear infinite;
    z-index: 0;
  }
  .hero__photo-ring:hover {
    transform: scale(1.05);
  }
  @keyframes hue-spin {
    0%   { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
  }
  .hero__photo {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-bg);
  }

  /* ── Stats bar ──────────────────────────────────────── */
  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .hero__stat {
    text-align: center;
  }
  .hero__stat-value {
    display: block;
    font-size: 1.8rem;
    font-weight: 800;
  }
  .hero__stat-label {
    font-size: .8rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  /* ── Scroll indicator ───────────────────────────────── */
  .hero__scroll {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    margin-top: 2.5rem;
  }
  .hero__mouse {
    width: 24px;
    height: 38px;
    border-radius: 12px;
    border: 2px solid var(--color-text-muted);
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }
  .hero__mouse-wheel {
    width: 3px;
    height: 8px;
    border-radius: 3px;
    background: var(--color-accent);
    animation: scroll-wheel 2s ease-in-out infinite;
  }
  @keyframes scroll-wheel {
    0%   { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(10px); }
  }
  .hero__scroll-text {
    font-size: .7rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero { padding: 6rem 0 2rem; }
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero__photo-wrap { order: -1; }
    .hero__photo-ring { width: 200px; height: 200px; }
    .hero__content { max-width: 100%; }
    .hero__subtitle { margin-left: auto; margin-right: auto; }
    .hero__actions { justify-content: center; }
    .hero__social { justify-content: center; }
    .hero__stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── CV Export Modal ────────────────────────────────── */
  .cv-modal {
    position: fixed;
    inset: 0;
    z-index: 10001;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity .3s ease;
  }
  .cv-modal--open {
    pointer-events: auto;
    opacity: 1;
  }
  .cv-modal__backdrop {
    position: absolute;
    inset: 0;
    background: var(--color-backdrop);
    backdrop-filter: blur(4px);
  }
  .cv-modal__panel {
    position: relative;
    width: 400px;
    max-width: calc(100vw - 2rem);
    padding: 2rem;
    transform: scale(.9) translateY(20px);
    transition: transform .35s cubic-bezier(.34,1.56,.64,1);
  }
  .cv-modal--open .cv-modal__panel {
    transform: scale(1) translateY(0);
  }
  .cv-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .75rem;
  }
  .cv-modal__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-heading);
  }
  .cv-modal__close {
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 50%;
    transition: color .2s, background .2s;
  }
  .cv-modal__close:hover {
    color: var(--color-text);
    background: var(--color-link-hover-bg);
  }
  .cv-modal__desc {
    font-size: .88rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .cv-modal__options {
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .cv-modal__option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    cursor: pointer;
    transition: border-color .2s, transform .2s, box-shadow .2s;
    text-align: left;
    color: var(--color-text);
    font-family: var(--font-sans);
  }
  .cv-modal__option:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .cv-modal__opt-label {
    display: block;
